  {
    "measure_name": "Avg Determination Turnaround Time (Days)",
    "measure_type": "Average",
    "classification": "Base Measure",
    "business_definition": "Average number of days from request receipt to decision date for determinations.",
    "formula_description": "AVERAGEX(FILTER(FactDeterminationAppeal, NOT ISBLANK(FactDeterminationAppeal[date_request_received_key]) && NOT ISBLANK(FactDeterminationAppeal[date_of_decision_key])), DATEDIFF(LOOKUPVALUE(DimDate[date], DimDate[date_key], FactDeterminationAppeal[date_request_received_key]), LOOKUPVALUE(DimDate[date], DimDate[date_key], FactDeterminationAppeal[date_of_decision_key]), DAY))",
    "source_tables": [
      "FactDeterminationAppeal",
      "DimDate"
    ],
    "source_fields": [
      "date_request_received_key",
      "date_of_decision_key",
      "date_key",
      "date"
    ],
    "dependencies": [],
    "report_pages": [
      "Executive Summary",
      "Trends & Timeliness"
    ],
    "visuals_used_in": [
      "Avg. Determination Turnaround Time (Days)",
      "Average Determination Turnaround Time by Month"
    ]
  },
